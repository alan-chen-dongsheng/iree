{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        // debug compile
        {
            "type": "lldb",
            "request": "launch",
            "name": "compile-debugger",
            "program": "${workspaceFolder}/build/tools/iree-compile",
            "cwd": "${workspaceFolder}",
            "args": [
                "/home/cds/workspace/iree/cds_test/mobilenetv2-12-batch1.mlir",
                "--iree-hal-target-device=local",
                "--iree-hal-local-target-device-backends=llvm-cpu",
                "--iree-llvmcpu-target-cpu=host",
                "-o",
                "/home/cds/workspace/iree/cds_test/mobilenetv2-12-batch1.vmfb",
            ],
        },
        // debug run time
        {
            "type": "lldb",
            "request": "launch",
            "name": "runtime-debugger",
            "program": "${workspaceFolder}/build/tools/iree-run-module",
            "cwd": "${workspaceFolder}",
            "args": [
                "--device",
                "local-task",
                "--module",
                "", // input file
                "--input",
                "1x1x1x1xi8=0" // output file
            ],
        },
    ]
}
